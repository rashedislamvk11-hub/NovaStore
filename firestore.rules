rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if true;
      allow write: if true;
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
